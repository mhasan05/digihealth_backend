{
  "info": {
    "name": "DigiHealth API",
    "description": "Complete API collection for DigiHealth hospital management system.\n\n## Setup\n1. Import this collection into Postman.\n2. Create an environment with `base_url = http://localhost:8000`.\n3. Use **Auth → Login** or **Auth → Demo Login** — the test script auto-saves the JWT to `{{token}}`.\n4. All protected endpoints use `Authorization: Bearer {{token}}` automatically.\n\n## Demo roles\n- `admin`, `owner`, `manager`, `pathologist`, `patient`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Auth",
      "item": [

        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); }"
          ], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"+8801700000001\",\n  \"password\": \"admin123\",\n  \"method\": \"phone\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] }
          }
        },

        {
          "name": "Demo Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); }"
          ], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/auth/demo-login/", "host": ["{{base_url}}"], "path": ["api", "auth", "demo-login", ""] },
            "description": "role can be: admin | owner | manager | pathologist | patient"
          }
        },

        {
          "name": "Register Patient",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"+8801900000099\",\n  \"password\": \"secret123\",\n  \"age\": 30,\n  \"gender\": \"Male\",\n  \"blood_group\": \"O+\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""] }
          }
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/api/auth/logout/", "host": ["{{base_url}}"], "path": ["api", "auth", "logout", ""] }
          }
        }

      ]
    },

